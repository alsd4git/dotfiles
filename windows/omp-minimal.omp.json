{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "style": "plain",
          "properties": {
            "branch_icon": ""
          },
          "template": "{{ if .HEAD }}[{{ .HEAD }}] {{ end }}",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "style": "plain",
          "template": "{{ if gt .Code 0 }}ERR{{ end }}",
          "type": "status"
        },
        {
          "style": "plain",
          "properties": {
            "time_format": "Mon 15:04"
          },
          "template": "{{ .CurrentDate | date .Format }}",
          "type": "time"
        },
        {
          "style": "plain",
          "properties": {
            "threshold": 0
          },
          "template": "{{ .FormattedMs }}",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 3
}
